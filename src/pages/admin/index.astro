---
import AdminApp from "@/components/admin/AdminApp";
---

<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Leiding Admin • Chiro Negenmanneke</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/png" href="/assets/Chirologo_700px.png" />
    <link rel="stylesheet" href="/assets/styles.css" />
    <link rel="stylesheet" href="/assets/admin.css" />
  </head>
  <body>
    <AdminApp client:only="preact">
      <div slot="fallback" class="admin-app admin-shell">
        <div class="admin-splash">
          <div class="admin-splash-mark" aria-hidden="true">9M</div>
          <p class="admin-kicker">Leiding Admin</p>
          <h1>Admin wordt geladen</h1>
          <p class="muted">
            We laden het beheerpaneel in. Als dit langer dan een paar seconden duurt, ververs dan
            de pagina.
          </p>
          <div class="admin-loader" aria-hidden="true"></div>
          <p class="admin-loading-hint">De login en je dashboard worden zo meteen opgehaald.</p>
        </div>
      </div>
    </AdminApp>
  </body>
</html>
