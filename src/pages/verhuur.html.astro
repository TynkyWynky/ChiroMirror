---
import PublicLayout from "@/layouts/PublicLayout.astro";
import SimpleCardsPage from "@/components/SimpleCardsPage.astro";
import { loadSiteContent } from "@/lib/content";

const content = await loadSiteContent();
const { siteSettings, pages } = content;
---

<PublicLayout
  title="Verhuur • Chiro Negenmanneke"
  description={pages.rental.description}
  siteSettings={siteSettings}
>
  <SimpleCardsPage page={pages.rental} />
</PublicLayout>
