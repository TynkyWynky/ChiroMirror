---
import Footer from "@/components/Footer.astro";
import Navbar from "@/components/Navbar.astro";
import type { SiteSettings } from "@/types/content";

interface Props {
  title: string;
  description: string;
  siteSettings: SiteSettings;
  socialImage?: string;
  showMapFooter?: boolean;
  noIndex?: boolean;
}

const {
  title,
  description,
  siteSettings,
  socialImage = siteSettings.logoUrl,
  showMapFooter = false,
  noIndex = false
} = Astro.props;

function resolveBaseUrl(value: string) {
  try {
    return new URL(value).toString();
  } catch {
    return Astro.url.origin;
  }
}

function resolveUrl(value: string, base: string) {
  try {
    return new URL(value, base).toString();
  } catch {
    return value;
  }
}

const siteBaseUrl = resolveBaseUrl(siteSettings.siteUrl);
const canonicalUrl = resolveUrl(Astro.url.pathname, siteBaseUrl);
const socialImageUrl = socialImage.startsWith("http")
  ? socialImage
  : resolveUrl(socialImage, siteBaseUrl);
---

<!DOCTYPE html>
<html lang="nl">
  <head>
    <link rel="canonical" href={canonicalUrl} />

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="icon" type="image/png" href={siteSettings.logoUrl} />
    <link rel="apple-touch-icon" href={siteSettings.logoUrl} />
    <link rel="stylesheet" href="/assets/styles.css" />
    <script is:inline defer src="/assets/script.js"></script>

    {siteSettings.analyticsId && (
      <>
        <meta name="x-analytics-id" content={siteSettings.analyticsId} />
        <script
          is:inline
          async
          src={`https://www.googletagmanager.com/gtag/js?id=${siteSettings.analyticsId}`}
        ></script>
        <script is:inline defer src="/assets/analytics.js"></script>
      </>
    )}

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="nl_BE" />
    <meta property="og:site_name" content={siteSettings.siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />

  </head>

  <body>
    <Navbar />
    <slot name="afterNav" />
    <main class="container">
      <slot />
    </main>
    <Footer siteSettings={siteSettings} showMap={showMapFooter} />
  </body>
</html>
